;;
;; Routing of a Contract AgentSBT
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'collectionAddress, $self'itemIndex, $self'owner, $self'content, $self'authorityAddress, $self'revokedAt, $self'isInitialized, $self'soulHash, $self'paymentAddress) = $AgentSBT$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    var op = in_msg~load_opcode_internal();
    ;; Receive MintItem message
    if (op == 1358695337) {
        var $msg'agentOwner = in_msg~load_msg_addr();
        var $msg'soulHash = in_msg~load_uint(256);
        var $msg'paymentAddress = in_msg~load_msg_addr();
        var $msg'content = in_msg~load_ref();
        throw_unless(2977, (~ $self'isInitialized));
        throw_unless(49621, ( equal_slices_bits(__tact_context_get_sender(), $self'collectionAddress) ));
        $self'isInitialized = true;
        $self'owner = $msg'agentOwner;
        $self'content = $msg'content;
        $self'soulHash = $msg'soulHash;
        $self'paymentAddress = $msg'paymentAddress;
        $self'authorityAddress = $self'collectionAddress;
        $AgentSBT$_contract_store(($self'collectionAddress, $self'itemIndex, $self'owner, $self'content, $self'authorityAddress, $self'revokedAt, $self'isInitialized, $self'soulHash, $self'paymentAddress));
        return ();
    }
    
    ;; Receive Transfer message
    if (op == 0x5fcc3d14) {
        var $msg'queryId = in_msg~load_uint(64);
        var $msg'newOwner = in_msg~load_msg_addr();
        var $msg'responseDestination = in_msg~load_msg_addr();
        var $msg'customPayload = in_msg~load_maybe_ref();
        var $msg'forwardAmount = in_msg~load_varuint16();
        var $msg'forwardPayload = in_msg;
        throw_unless(25236, false);
        $AgentSBT$_contract_store(($self'collectionAddress, $self'itemIndex, $self'owner, $self'content, $self'authorityAddress, $self'revokedAt, $self'isInitialized, $self'soulHash, $self'paymentAddress));
        return ();
    }
    
    ;; Receive ProveOwnership message
    if (op == 0x4ded148) {
        var $msg'queryId = in_msg~load_uint(64);
        var $msg'dest = in_msg~load_msg_addr();
        var $msg'forwardPayload = in_msg~load_ref();
        var $msg'withContent = in_msg~load_int(1);
        throw_unless(14534, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        $global_send($SendParameters$_constructor_to_value_mode_body($msg'dest, 0, 64, $OwnershipProof$_store_cell($OwnershipProof$_constructor_queryId_itemId_owner_data_revokedAt_content($msg'queryId, $self'itemIndex, $self'owner, $msg'forwardPayload, $self'revokedAt, ($msg'withContent ? $self'content : null())), begin_cell())));
        $AgentSBT$_contract_store(($self'collectionAddress, $self'itemIndex, $self'owner, $self'content, $self'authorityAddress, $self'revokedAt, $self'isInitialized, $self'soulHash, $self'paymentAddress));
        return ();
    }
    
    ;; Receive RequestOwner message
    if (op == 0xd0c3bfea) {
        var $msg'queryId = in_msg~load_uint(64);
        var $msg'dest = in_msg~load_msg_addr();
        var $msg'forwardPayload = in_msg~load_ref();
        var $msg'withContent = in_msg~load_int(1);
        $global_send($SendParameters$_constructor_to_value_mode_body($msg'dest, 0, 64, $OwnerInfo$_store_cell($OwnerInfo$_constructor_queryId_itemId_initiator_owner_data_revokedAt_content($msg'queryId, $self'itemIndex, __tact_context_get_sender(), $self'owner, $msg'forwardPayload, $self'revokedAt, ($msg'withContent ? $self'content : null())), begin_cell())));
        $AgentSBT$_contract_store(($self'collectionAddress, $self'itemIndex, $self'owner, $self'content, $self'authorityAddress, $self'revokedAt, $self'isInitialized, $self'soulHash, $self'paymentAddress));
        return ();
    }
    
    ;; Receive GetStaticData message
    if (op == 0x2fcb26a2) {
        var $msg'queryId = in_msg~load_uint(64);
        $global_send($SendParameters$_constructor_to_value_mode_body(__tact_context_get_sender(), 0, 64, $ReportStaticData$_store_cell($ReportStaticData$_constructor_queryId_indexId_collection($msg'queryId, $self'itemIndex, $self'collectionAddress), begin_cell())));
        $AgentSBT$_contract_store(($self'collectionAddress, $self'itemIndex, $self'owner, $self'content, $self'authorityAddress, $self'revokedAt, $self'isInitialized, $self'soulHash, $self'paymentAddress));
        return ();
    }
    
    ;; Receive Revoke message
    if (op == 0x6f89f5e3) {
        var $msg'queryId = in_msg~load_uint(64);
        throw_unless(58800, ( equal_slices_bits(__tact_context_get_sender(), $self'authorityAddress) ));
        throw_unless(10990, ($self'revokedAt == 0));
        $self'revokedAt = $global_now();
        $AgentSBT$_contract_store(($self'collectionAddress, $self'itemIndex, $self'owner, $self'content, $self'authorityAddress, $self'revokedAt, $self'isInitialized, $self'soulHash, $self'paymentAddress));
        return ();
    }
    
    ;; Receive Destroy message
    if (op == 0x1f04537a) {
        var $msg'queryId = in_msg~load_uint(64);
        throw_unless(14534, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        $global_send($SendParameters$_constructor_to_value_mode_body($self'owner, 0, 128, $Excesses$_store_cell($Excesses$_constructor_queryId($msg'queryId), begin_cell())));
        $self'owner = $self'collectionAddress;
        $self'authorityAddress = $self'collectionAddress;
        $self'isInitialized = false;
        $AgentSBT$_contract_store(($self'collectionAddress, $self'itemIndex, $self'owner, $self'content, $self'authorityAddress, $self'revokedAt, $self'isInitialized, $self'soulHash, $self'paymentAddress));
        return ();
    }
    
    ;; Throw if not handled
    throw(130);
}


() __tact_selector_hack_asm() impure asm """
@atend @ 1 {
        execute current@ context@ current!
        {
            // The core idea of this function is to save gas by avoiding unnecessary dict jump, when recv_internal/recv_external is called
            // We want to extract recv_internal/recv_external from the dict and select needed function
            // not by jumping to the needed function by it's index, but by using usual IF statements.

            }END> b> // Close previous builder, now we have a cell of previous code on top of the stack

            <{ // Start of the new code builder
                SETCP0
                // Swap the new code builder with the previous code, now we have previous code on top of the stack
                swap
                // Transform cell to slice and load first ref from the previous code, now we have the dict on top of the stack
                <s ref@

                // Extract the recv_internal from the dict
                dup 0 swap @procdictkeylen idict@ { "internal shortcut error" abort } ifnot
                swap

                // Delete the recv_internal from the dict
                0 swap @procdictkeylen idict- drop
                // Delete the recv_external from the dict (it's okay if it's not there)
                -1 swap @procdictkeylen idict- drop
                // Delete the __tact_selector_hack from the dict
                65535 swap @procdictkeylen idict- drop

                // Bring the code builder from the bottom of the stack
                // because if recv_external extraction is optional, and the number of elements on the stack is not fixed
                depth 1- roll
                // Swap with the dict from which we extracted recv_internal and (maybe) recv_external
                swap

                // Check if the dict is empty
                dup null?
                // Store a copy of this flag in the bottom of the stack
                dup depth 1- -roll
                {
                    // If the dict is empty, just drop it (it will be null if it's empty)
                    drop
                }
                {
                    // If the dict is not empty, prepare continuation to be stored in c3
                    <{
                        // Save this dict as first ref in this continuation, it will be pushed in runtime by DICTPUSHCONST
                        swap @procdictkeylen DICTPUSHCONST
                        // Jump to the needed function by it's index
                        DICTIGETJMPZ
                        // If such key is not found, throw 11 along with the key as an argument
                        11 THROWARG
                    }> PUSHCONT
                    // Store the continuation in c3
                    c3 POP
                } cond

                // Function id is on top of the (runtime) stack
                DUP IFNOTJMP:<{
                    // place recv_internal here
                    DROP swap @addop
                }>

                // Bring back the flag, indicating if the dict is empty or not from the bottom of the stack
                depth 1- roll
                {
                    // If the dict is empty, throw 11
                    11 THROWARG
                }
                {
                    // If the dict is not empty, jump to continuation from c3
                    c3 PUSH JMPX
                } cond
            }> b>
        } : }END>c
        current@ context! current!
    } does @atend !
""";

() __tact_selector_hack() method_id(65535) {
    return __tact_selector_hack_asm();
}